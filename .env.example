# Optional overrides — NOT required when the app runs with an IAM role (EC2/ECS/EKS/Lambda).
# Copy only if you need local overrides; rename to .env only when Compose must inject vars.

# AWS_REGION=eu-west-1
# AWS_SECRETS_SECRET_NAME=your-secret-id-or-name

# Local development without an IAM role (prefer: aws sso login + mount ~/.aws in Compose):
# AWS_PROFILE=your-profile
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# CORS_ORIGINS=https://dashboard.example.com
# DEBUG=false
