# ─────────────────────────────────────────────────────────────
# Proxmox Cluster Dashboard - Configuration
# Copia questo file in .env e modifica i valori secondo le tue esigenze
# ─────────────────────────────────────────────────────────────

# ── Applicazione ──────────────────────────────────────────────
APP_NAME=Proxmox Cluster Dashboard
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database - PostgreSQL su AWS RDS ───────────────────────────
DB_HOST=syam-projectwork-pontos.c9nj1x2p6gk5.eu-west-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=pontos
DB_PASSWORD=change-me
DB_SSLMODE=require
DB_SSLROOTCERT=

# ── Autenticazione Proxmox ────────────────────────────────────
# I nodi vengono auto-discoverati dal cluster Proxmox via API
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=change-me

# OPZIONE 2: API Token (consigliato per sicurezza)
PROXMOX_TOKEN_NAME=automation@pam!dashboard-token
PROXMOX_TOKEN_VALUE=your-token-value-here

PROXMOX_VERIFY_SSL=false

# ── Security ───────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── Polling Intervals (secondi) ───────────────────────────────
METRICS_POLL_INTERVAL=30
LOGS_POLL_INTERVAL=10
SERVICES_POLL_INTERVAL=60

# ── Costi Infrastruttura ──────────────────────────────────────
ELECTRICITY_COST_KWH=0.28
NODE_TDP_IDLE_W=20.0
NODE_TDP_MAX_W=65.0
NODE_HOURS_PER_MONTH=730.0
COOLING_OVERHEAD_PCT=20.0
MONTHLY_CONNECTIVITY=50.0
PROXMOX_SUBSCRIPTION_PER_NODE=10.0
MONTHLY_BACKUP_OFFSITE=10.0
HARDWARE_COST_PER_NODE=800.0
HARDWARE_AMORTIZATION_MONTHS=48.0
MONTHLY_BUDGET=500.0