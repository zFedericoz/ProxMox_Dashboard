# ─────────────────────────────────────────────────────────────────────────────
# Proxmox Cluster Dashboard - Local Development
# ─────────────────────────────────────────────────────────────────────────────
# Questo file è per lo SVILUPPO LOCALE SOLO.
# NON committare mai questo file su git! (.gitignore lo esclude già)
# ─────────────────────────────────────────────────────────────────────────────

DEBUG=true
PORT=8000
AWS_REGION=eu-west-1
AWS_SECRETS_SECRET_NAME=syam-projectwork-pontos

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Ottieni le credenziali da AWS IAM -> Utenti -> Security credentials
# NOTA: in produzione usa IAM Role, non Access Keys
AWS_ACCESS_KEY_ID=INSERISCI_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=INSERISCI_AWS_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=

PROXMOX_VERIFY_SSL=false
METRICS_POLL_INTERVAL=30
LOGS_POLL_INTERVAL=10
SERVICES_POLL_INTERVAL=60

# ── Infrastructure Costs (non sensibili) ─────────────────────────────────────
ELECTRICITY_COST_KWH=0.28
NODE_TDP_IDLE_W=20.0
NODE_TDP_MAX_W=65.0
NODE_HOURS_PER_MONTH=730.0
COOLING_OVERHEAD_PCT=20.0
MONTHLY_CONNECTIVITY=50.0
PROXMOX_SUBSCRIPTION_PER_NODE=10.0
MONTHLY_BACKUP_OFFSITE=10.0
HARDWARE_COST_PER_NODE=800.0
HARDWARE_AMORTIZATION_MONTHS=48.0
MONTHLY_BUDGET=500.0